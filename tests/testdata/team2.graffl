@prefix http://example.org/team2/



---- Ontology ----------------

TeamMember : Class
    icon tests/icons/user.png

TeamLead : Class
    subClassOf -> TeamMember
    color #FF0000

worksWith a Property ; "arbeitet zusammen mit"
    comment "rdfs comment"
    color "#00FF00"

on a Property
    color "#FF7777"
    lineType "dashed"
    targetArrow "none"

Note a Class
    color "#FFCCCC"
    shape "rectangle"

--------------------------------



----"Team 1"-----

    Alice : TeamLead icon tests/icons/alice.png

    Bob : TeamMember

    Chris : TeamMember


-----------------

  "Team 1" membershipOrder [
            1. -> Alice
            2. -> Chris
            4321. -> Bob
        ]

----"Team 2"-----

    David : TeamLead

    Egon : TeamMember

-----------------


----"ART Graph"-----

 "Team 1"

 "Team 2"

 "Team 1" worksWith -> "Team 2"

--------------------