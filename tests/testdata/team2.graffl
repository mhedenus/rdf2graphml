@prefix http://example.org/team2/



---- Ontology ----------------

TeamMember : Class
    icon tests/icons/user.png

TeamLead : Class
    subClassOf -> TeamMember
    color #FF0000

worksWith a Property ; "arbeitet zusammen mit"
    comment "rdfs comment"
    color "#00FF00"


(for) a Property
    label "note for"
    color "#FF7777"
    lineType "dashed"
    targetArrow "none"

Note a Class
    color "#FFCCCC"
    shape "rectangle"

--------------------------------




(1) : Note for -> Alice
        label """
             Noch ein
             langer
             Kommentar
             x
             y
             z
             lödkafds
             alökf asd lfösdlöf jlöasd fasdf dasdasd
            """



----"Team 1"-----

    Alice : TeamLead ; """
        bla 1
        bla 2
        bla 3
    """

    (2) : Note label "Innerer Kommentar" for -> Alice



    Bob : TeamMember ; "high performer"

    Chris : TeamMember

-----------------


----"Team 2"-----

    David : TeamLead

    Egon : TeamMember

-----------------


----"ART Graph"-----



 "Team 1" note [  : Note label "Bemerkung" ]

 "Team 2"

 "Team 1" worksWith -> "Team 2"

