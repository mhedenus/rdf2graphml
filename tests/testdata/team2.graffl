@prefix http://example.org/team2/

note1 : Note label """
 Hier steht
 was!
"""


TeamMember : Class
    icon tests/icons/user.png
    note -> note1

TeamLead : Class
    subClassOf -> TeamMember
    color #FF0000

worksWith a Property

"Team 1" worksWith -> "Team 2"





----"Team 1"-----

    Alice : TeamLead
    comment """
        bla 1
        bla 2
        bla 3
    """

    Bob : TeamMember

    Chris : TeamMember

