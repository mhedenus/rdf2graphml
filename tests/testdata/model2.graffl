@ prefix <http://example.org/ns#>
@ my = <http://example.org/ns#>
@ use RDFSchema
@ use OWL
@ use SHACL

MyClass : Class
    subClassOf [
        label "status ACTIVE"
         : Restriction
        onProperty status
        owl:hasValue "ACTIVE"
        ]

"status ACTIVE" : NodeShape
    targetClass MyClass
    property [ : PropertyShape
        path status
        sh:hasValue "ACTIVE"
    ]