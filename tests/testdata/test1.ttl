@base <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rel: <http://www.perceive.net/schemas/relationship/> .
@prefix rdf2graphml: <https://www.hedenus.de/rdf2graphml/> .


<a> a foaf:Person;
    rdfs:label "Heidi"@de ;
    rdfs:label "Alice" ;
    rdfs:label "Adelheid"@de ;
    foaf:mbox <mailto:alice@example.org>, <mailto:a@b.org>  ;
    foaf:img "../icons/alice.png" ;
    <geheimesProperty1> "GEHEIM!" .

<b> a foaf:Person ;
    rdfs:label "Bob" ;
    foaf:mbox <mailto:bob@example.org> ;
    foaf:knows <a> .


<c> a foaf:Person ;
    rdfs:label "Chris" ;
    foaf:knows <b> ;
    rdf2graphml:color "#FF0000" ;
    rdf2graphml:shape "rectangle" ;
    foaf:knows [
        a rdf2graphml:Link ;
        rdfs:label "Somebody" ;
        rdf:value "https://www.hedenus.de"
        ] .
