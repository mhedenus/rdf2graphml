@ context <http://example.org/sys/model>
@ prefix  <http://example.org/sys/elements#>
@ use RDFSchema
@ use OWL
@ use rdf2graphml

// the model (ontology)
// enriched with layout annotations

SystemOntology : Ontology
    typeAsEdge false

---- "Core Types" ----

System : Class ; "The base class of all systems"

prototypeOf : Property

Note : Class
    color #FFAAAA
    shape rectangle

note : Property
    color #FFAAAA
    lineWidth: 4

---------------------


---- "Application Types" ----

BatteryHolder : Class
    subClassOf System ; "A holder for 3 batteries"
    icon "tests/icons/battery-holder.jpg"

Battery : Class
    subClassOf System ; "A battery consists of two connection points and some electrochemistry"
    icon "tests/icons/battery.png"

ConnectionPoint : Class
    subClassOf System
    shape diamond
    color #AAAAFF

Electrochemistry : Class
    subClassOf System

connectedTo : Property
    targetArrow none

electricFlow : Property
    color #7e0000

----------------------------------