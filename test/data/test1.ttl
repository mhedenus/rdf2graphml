@base <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rel: <http://www.perceive.net/schemas/relationship/> .


<a> a foaf:Person;
    rdfs:label "Heidi"@de ;
    rdfs:label "Alice" ;
    rdfs:label "Adelheid"@de ;
    foaf:mbox <mailto:alice@example.org>, <mailto:a@b.org>  ;
    foaf:img "images/alice.png" ;
    <geheimesProperty1> "GEHEIM!" ;
    <arbeitetMit> (<s1> <s2> <s3> <s4>).

<s1> a <System> ;
    rdfs:label "System 1" .

<s2> a <System> ;
    rdfs:label "System 2" .

<s3> a <System> ;
    rdfs:label "System 3" .

<s4> a <System> ;
    rdfs:label "System 4" .

<b> a foaf:Person ;
    rdfs:label "Bob" ;
    foaf:mbox <mailto:bob@example.org> ;
    foaf:knows <a> .
