  schema:birthDate "1950-08-15"^^xsd:date ;
  schema:jobTitle "Princess Royal" ;
  schema:url <https://www.royal.uk/the-princess-royal> ;
  foaf:homepage <https://www.royal.uk/the-princess-royal> ;
  schema:parent ex:elizabethII ;
  schema:sibling ex:charlesIII .

ex:edward a schema:Person, foaf:Person ;
  rdfs:label "Edward, Duke of Edinburgh"@de ;
