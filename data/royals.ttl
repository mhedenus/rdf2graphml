ex:charlesIII a schema:Person, foaf:Person ;
  rdfs:label "König Charles III."@de ;
  rdfs:comment "Der amtierende britische Monarch und Staatsoberhaupt des Vereinigten Königreichs."@de ;
  schema:name "Charles III" ;
  schema:birthDate "1948-11-14"^^xsd:date ;
  schema:jobTitle "King of the United Kingdom" ;
  schema:url <https://www.royal.uk/the-king> ;
  foaf:homepage <https://www.royal.uk/the-king> ;
  foaf:img <https://upload.wikimedia.org/wikipedia/commons/a/ac/King_Charles_III_%28July_2023%29.jpg> ;
  schema:parent ex:elizabethII .

ex:camilla a schema:Person, foaf:Person ;
  rdfs:label "Königin Camilla"@de ;
  rdfs:comment "Gemahlin von König Charles III. und Mitglied der britischen Königsfamilie."@de ;
