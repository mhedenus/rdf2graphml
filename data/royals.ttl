  schema:birthDate "1947-07-17"^^xsd:date ;
  schema:jobTitle "Queen Consort" ;
  schema:url <https://www.royal.uk/the-queen-consort> ;
  foaf:homepage <https://www.royal.uk/the-queen-consort> ;
  foaf:img <https://upload.wikimedia.org/wikipedia/commons/c/c9/Queen_Camilla_in_Aotearoa_2019.jpg> ;
  schema:spouse ex:charlesIII .

ex:william a schema:Person, foaf:Person ;
  rdfs:label "William, Prince of Wales"@de ;
  rdfs:comment "Thronfolger des Vereinigten Königreichs und Sohn von König Charles III."@de ;
