  schema:jobTitle "Prince of Wales" ;
  schema:url <https://www.royal.uk/the-prince-of-wales> ;
  foaf:homepage <https://www.royal.uk/the-prince-of-wales> ;
  foaf:img <https://upload.wikimedia.org/wikipedia/commons/e/ec/2023_Prince_of_Wales_%28cropped%2902.JPG> ;
  schema:parent ex:charlesIII ;
  schema:spouse ex:kate .

ex:kate a schema:Person, foaf:Person ;
